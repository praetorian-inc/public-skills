    {
      "id": "perplexity.search",
      "name": "Perplexity Search",
      "description": "Perform web search using the Perplexity Search API with ranked results.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "description": "Search query string"
          },
          "max_results": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "description": "Maximum number of results to return (1-20, default: 10)"
          },
          "max_tokens_per_page": {
            "type": "integer",
            "minimum": 256,
            "maximum": 2048,
            "description": "Maximum tokens to extract per webpage (default: 1024)"
          },
          "country": {
            "type": "string",
            "minLength": 2,
            "maxLength": 2,
            "pattern": "^[A-Z]{2}$",
            "description": "ISO 3166-1 alpha-2 country code (e.g., US, GB)"
          }
        },
        "required": [
          "query"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "Search results as plain text"
          },
          "metadata": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              },
              "resultCount": {
                "type": "number"
              }
            },
            "required": [
              "query"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "content"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "auth": [
        "PERPLEXITY_API_KEY"
      ],
      "wraps": {
        "type": "rest"
      },
      "entry": "wrapper.ts#perplexitySearch",
      "schemaHash": "d0258c491d6a0450e38b18ad51579310d5e8594d1db392a82e088a6c237cf90b"
    }
